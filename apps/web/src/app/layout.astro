---
import { YandexMetrika } from "astro-ym";
import { Seo } from "astro-seo-meta";
import { Font } from "astro:assets";
import { Schema } from "astro-seo-schema";
import { contacts } from "@/pages-flat/home/config/contacts";
import { buildCoursesOfferCatalog } from "@/pages-flat/home/config/courses";
import {
  openingHoursSpecification,
  school
} from "@/pages-flat/home/config/school";
import type { EducationalOrganization, Graph, WebPage } from "schema-dts";
import "./styles.css";

const site = import.meta.env.SITE;
const organizationId = `${site}#organization`;

const title = school.title;
const description = school.description;

const keywords = [
  "школа программирования",
  "школа программирования Владимир",
  "школа программирования для детей",
  "курсы программирования",
  "обучение программированию",
  "программирование для детей",
  "программирование для школьников",
  "Python для детей",
  "C# для детей",
  "Scratch для детей",
  "Pygame",
  "Godot для детей",
  "геймдев для детей",
  "IT курсы",
  "обучение IT",
  "программирование с нуля",
  "детские курсы программирования",
  "уроки программирования онлайн",
  "офлайн курсы программирования",
  "индивидуальные занятия программированием",
  "групповые занятия программированием",
  "курсы программирования Владимир"
];

const education: EducationalOrganization = {
  "@type": "EducationalOrganization",
  "@id": organizationId,
  name: school.name,
  alternateName: [...school.alternateNames],
  url: site,
  description: description,
  telephone: contacts.phone.format("E.164"),
  areaServed: "RU",
  foundingDate: String(school.foundingYear),
  address: {
    "@type": "PostalAddress",
    streetAddress: contacts.address.streetAddress,
    addressLocality: contacts.address.locality,
    postalCode: contacts.address.postalCode,
    addressCountry: "RU"
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 56.134151,
    longitude: 40.415219
  },
  openingHoursSpecification: [openingHoursSpecification],
  sameAs: [contacts.vk, contacts.telegram, contacts.max],
  image: {
    "@type": "ImageObject",
    url: `${site}/og-image.jpg`
  },
  hasOfferCatalog: buildCoursesOfferCatalog(organizationId)
};

const webpage: WebPage = {
  "@type": "WebPage",
  name: title,
  description: description,
  url: site,
  image: {
    "@type": "ImageObject",
    url: `${site}/og-image.jpg`
  },
  inLanguage: "ru",
  isPartOf: {
    "@type": "WebSite",
    name: "КодКрафт",
    url: site
  },
  about: {
    "@id": organizationId
  }
};

const graph: Graph = {
  "@context": "https://schema.org",
  "@graph": [education, webpage]
};
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, minimum-scale=1"
    />

    <Seo
      title={title}
      description={description}
      keywords={keywords}
      icon="/favicon.ico"
      robots="index, follow"
      colorScheme="light"
      themeColor="#f40"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={school.name} />
    <meta property="og:url" content={site} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:image" content={`${site}/og-image.jpg`} />
    <meta property="og:image:secure_url" content={`${site}/og-image.jpg`} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <Font cssVariable="--font-wix" preload />

    <Schema item={graph} />

    {
      import.meta.env.PROD && (
        <YandexMetrika counterId={109849817} ecommerce="dataLayer" webvisor />
      )
    }
  </head>
  <body class="pt-12 md:pt-16">
    <slot />
  </body>
</html>
