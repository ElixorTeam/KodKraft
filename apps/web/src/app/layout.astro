---
import { YandexMetrika } from "astro-ym";
import { Seo } from "astro-seo-meta";
import { Font } from "astro:assets";
import { Schema } from "astro-seo-schema";
import { contacts, formatPhone } from "@/pages-flat/home/config/contacts";
import { buildCoursesOfferCatalog } from "@/pages-flat/home/config/courses";
import { buildReviewsSchema } from "@/pages-flat/home/config/reviews";
import type { EducationalOrganization, Graph, WebPage } from "schema-dts";
import "./styles.css";

const site = import.meta.env.SITE;
const organizationId = `${site}#organization`;

const title = "КодКрафт — курсы программирования для детей во Владимире";
const description =
    "Научим детей программировать с нуля через практику и свои проекты. Офлайн во Владимире и онлайн по всей России. Первый урок бесплатно. Работаем с 2018.";

const keywords = [
  "кодкрафт",
  "кодкрафт33",
  "kodkraft33",
  "kodkraft",
  "школа программирования",
  "курсы программирования",
  "обучение программированию",
  "программирование для детей",
  "программирование для школьников",
  "Python для детей",
  "C# для детей",
  "Scratch для детей",
  "Pygame",
  "Godot для детей",
  "геймдев для детей",
  "IT курсы",
  "обучение IT",
  "программирование с нуля",
  "детские курсы программирования",
  "уроки программирования онлайн",
  "офлайн курсы программирования",
  "индивидуальные занятия программированием",
  "групповые занятия программированием",
  "курсы программирования Владимир"
];

const reviewsSchema = buildReviewsSchema(organizationId);

const education: EducationalOrganization = {
  "@type": "EducationalOrganization",
  "@id": organizationId,
  name: "КодКрафт",
  description: description,
  telephone: formatPhone(contacts.phone),
  areaServed: "RU",
  foundingDate: "2018",
  address: {
    "@type": "PostalAddress",
    streetAddress: contacts.address.streetAddress,
    addressLocality: contacts.address.locality,
    postalCode: contacts.address.postalCode,
    addressCountry: "RU"
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 56.134151,
    longitude: 40.415219
  },
  openingHours: "Mo-Su 09:00-21:00",
  sameAs: [
    contacts.vk,
    contacts.telegram,
    contacts.max
  ],
  image: {
    "@type": "ImageObject",
    url: `${site}/og-image.jpg`,
  },
  aggregateRating: reviewsSchema.aggregateRating,
  review: reviewsSchema.review,
  hasOfferCatalog: buildCoursesOfferCatalog(organizationId)
};

const webpage: WebPage = {
  "@type": "WebPage",
  name: title,
  description: description,
  url: site,
  image: {
    "@type": "ImageObject",
    url: `${site}/og-image.jpg`,
  },
  inLanguage: "ru",
  isPartOf: {
    "@type": "WebSite",
    name: "КодКрафт",
    url: site
  },
  about: {
    "@id": organizationId
  }
};

const graph: Graph = {
  "@context": "https://schema.org",
  "@graph": [education, webpage]
};
---

<html lang="ru">
  <head>
    <title>{title}</title>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1" />

    <!-- Яндекс.Вебмастер -->
    <meta name="yandex-verification" content="4d0c735452a87c36" />

    <Seo
        title={title}
        description={description}
        keywords={keywords}
        icon="/favicon.ico"
        robots="index, follow"
        colorScheme="light"
        themeColor="#ff4500"
    />

    <meta property="og:type" content="website">
    <meta property="og:site_name" content="КодКрафт">
    <meta property="og:url" content={site}>
    <meta property="og:image" content={`${site}/og-image.jpg`} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <Font cssVariable="--font-wix" preload />


    <!-- JSON-LD -->
    <Schema item={graph} />

    <!-- Яндекс.Метрика -->
    {
      import.meta.env.PROD && (
        <YandexMetrika
          counterId={109710042}
          ecommerce="dataLayer"
          webvisor
          lazy
        />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
