---
import { YandexMetrika } from "astro-ym";
import { Seo } from "astro-seo-meta";
import { Font } from "astro:assets";
import { Schema } from "astro-seo-schema";
import { contacts } from "@/pages-flat/home/config/contacts";
import { courses } from "@/pages-flat/home/config/courses";
import type { EducationalOrganization, Graph, WebPage } from "schema-dts";
import "./styles.css";

const title = "КодКрафт – Школа программирования";
const description =
  "Курсы по Python, C#, Scratch, web-разработке и гейм-разработке для детей и взрослых.";

const keywords = [
  "кодкрафт",
  "школа программирования",
  "курсы программирования",
  "Python",
  "JavaScript",
  "дети",
  "web-разработка",
  "робототехника"
];

const education: EducationalOrganization = {
  "@type": "EducationalOrganization",
  name: "КодКрафт",
  description: description,
  telephone: contacts.phone?.formatNational(),
  email: contacts.email,
  areaServed: "RU",
  foundingDate: "2018",
  address: {
    "@type": "PostalAddress",
    streetAddress: "ул. Чехова, 5",
    addressLocality: "Владимир",
    postalCode: "600006",
    addressCountry: "RU"
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 56.134151,
    longitude: 40.415219
  },
  openingHours: "Mo-Su 09:00-21:00",
  sameAs: [
    contacts.avito,
    contacts.vk,
    contacts.telegram,
    contacts.whatsapp,
    contacts.max
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Курсы программирования",
    itemListElement: courses.map((item) => {
      return {
        "@type": "Course",
        name: item.name,
        description: item.description,
        provider: {
          "@type": "Organization",
          name: "КодКрафт"
        }
      };
    })
  }
};

const webpage: WebPage = {
  "@type": "WebPage",
  name: title,
  description: description,
  url: import.meta.env.SITE,
  inLanguage: "ru",
  isPartOf: {
    "@type": "WebSite",
    name: "КодКрафт",
    url: import.meta.env.SITE
  },
  about: {
    "@type": "EducationalOrganization",
    name: "КодКрафт"
  }
};

const graph: Graph = {
  "@context": "https://schema.org",
  "@graph": [education, webpage]
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, minimum-scale=1"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Font cssVariable="--font-wix" preload />

    <Seo
      title={title}
      description={description}
      keywords={keywords}
      icon="/favicon.ico"
      robots="index, follow"
      colorScheme="light"
      themeColor="#ff4500"
    />

    <!-- JSON-LD -->
    <Schema item={graph} />

    <!-- Яндекс.Вебмастер -->
    <meta name="yandex-verification" content="ef5c375d86ba34a4" />

    <!-- Яндекс.Метрика -->
    {
      import.meta.env.PROD && (
        <YandexMetrika
          counterId={107232679}
          ecommerce="dataLayer"
          webvisor
          lazy
        />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
