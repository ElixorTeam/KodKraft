---
import { YandexMetrika } from "astro-ym";
import { Seo } from "astro-seo-meta";
import { Font } from "astro:assets";
import { Schema } from "astro-seo-schema";
import { contacts, formatPhone } from "@/pages-flat/home/config/contacts";
import { courses } from "@/pages-flat/home/config/courses";
import type { EducationalOrganization, Graph, WebPage } from "schema-dts";
import "./styles.css";

const title = "КодКрафт – школа программирования для детей и подростков во Владимире";
const description =
    "Курсы по Python, C#, Scratch, web-разработке и гейм-разработке. Обучаем программированию с нуля онлайн и во Владимире, помогаем развивать интерес к технологиям и делать первые проекты.";

const keywords = [
  "кодкрафт",
  "кодкрафт33",
  "kodkraft33",
  "kodkraft",
  "школа программирования",
  "курсы программирования",
  "обучение программированию",
  "программирование для детей",
  "программирование для школьников",
  "Python для детей",
  "C# для детей",
  "Scratch программирование",
  "web-разработка",
  "IT курсы",
  "обучение IT",
  "программирование с нуля",
  "детские курсы программирования",
  "уроки программирования онлайн",
  "офлайн курсы программирования",
  "индивидуальные занятия программированием",
  "групповые занятия программированием",
  "курсы программирования Владимир"
];

const education: EducationalOrganization = {
  "@type": "EducationalOrganization",
  name: "КодКрафт",
  description: description,
  telephone: formatPhone(contacts.phone),
  areaServed: "RU",
  foundingDate: "2018",
  address: {
    "@type": "PostalAddress",
    streetAddress: "ул. Чехова, 5",
    addressLocality: "Владимир",
    postalCode: "600006",
    addressCountry: "RU"
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 56.134151,
    longitude: 40.415219
  },
  openingHours: "Mo-Su 09:00-21:00",
  sameAs: [
    contacts.vk,
    contacts.telegram,
    contacts.max
  ],
  image: {
    "@type": "ImageObject",
    url: `${import.meta.env.SITE}/og-image.webp`,
  },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Курсы программирования",
    itemListElement: courses.map((item) => {
      return {
        "@type": "Course",
        name: item.name,
        description: item.description,
        provider: {
          "@type": "Organization",
          name: "КодКрафт"
        }
      };
    })
  }
};

const webpage: WebPage = {
  "@type": "WebPage",
  name: title,
  description: description,
  url: import.meta.env.SITE,
  image: {
    "@type": "ImageObject",
    url: `${import.meta.env.SITE}/og-image.webp`,
  },
  inLanguage: "ru",
  isPartOf: {
    "@type": "WebSite",
    name: "КодКрафт",
    url: import.meta.env.SITE
  },
  about: {
    "@type": "EducationalOrganization",
    name: "КодКрафт"
  }
};

const graph: Graph = {
  "@context": "https://schema.org",
  "@graph": [education, webpage]
};
---

<html lang="ru">
  <head>
    <title>{title}</title>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1" />

    <!-- Яндекс.Вебмастер -->
    <!--<meta name="yandex-verification" content="ef5c375d86ba34a4" />-->

    <Seo
        title={title}
        description={description}
        keywords={keywords}
        icon="/favicon.ico"
        robots="index, follow"
        colorScheme="light"
        themeColor="#ff4500"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Font cssVariable="--font-wix" preload />
    <meta property="og:url" content={import.meta.env.SITE}>
    <meta property="og:image" content={`${import.meta.env.SITE}/og-image.webp`} />

    <!-- JSON-LD -->
    <Schema item={graph} />

    <!-- Яндекс.Метрика -->
    {
      // import.meta.env.PROD && (
      //   <YandexMetrika
      //     counterId={109710042}
      //     ecommerce="dataLayer"
      //     webvisor
      //     lazy
      //   />
      // )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
