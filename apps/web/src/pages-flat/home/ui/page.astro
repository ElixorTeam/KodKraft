---
import Header from "./header.astro";
import PixelChevronIcon from "@/shared/assets/icons/pixel-chevron.svg";
import { Button } from "@/shared/ui/button";
import { DialogTrigger } from "@/shared/ui/dialog";
import { Image } from "astro:assets";
import Footer from "./footer.astro";
import { CallbackDialog } from "@/widgets/callback-dialog";
import Courses from "./courses.astro";
import ContactUs from "./contact-us.astro";
import Teachers from "./teachers.astro";
import { Badge } from "@/shared/ui/badge";
import Gallery from "./gallery.astro";
import CtaBG from "@/shared/assets/cta-bg.webp";
import {
  Section,
  SectionContent,
  SectionDescription,
  SectionHeader,
  SectionTitle
} from "./section";
import Reviews from "./reviews.astro";
import Mario from "@/shared/assets/mario.webp";
import Ghost from "@/shared/assets/ghost.webp";
---

<CallbackDialog />

<Header />

<main class="relative container mx-auto size-full min-h-screen pt-12">
  <div class="animate-appear-zoom absolute -top-32 -z-10 w-full delay-1000">
    <div
      class="absolute left-1/2 h-64 w-[40%] -translate-x-1/2 scale-[2.5] rounded-[50%] bg-radial from-primary/75 from-10% to-primary/0 to-60% opacity-20 sm:h-128 dark:opacity-50"
    >
    </div>
    <div
      class="absolute left-1/2 h-32 w-[40%] -translate-x-1/2 scale-200 rounded-[50%] bg-radial from-primary/30 from-10% to-primary/0 to-60% opacity-20 sm:h-64 dark:opacity-50"
    >
    </div>
  </div>

  <section
    class="my-20 animate-in duration-1000 blur-in fade-in md:my-32 md:slide-in-from-bottom-15"
  >
    <div
      class="relative mx-auto flex w-full max-w-5xl flex-col items-center justify-center gap-4 px-4 text-center sm:px-6 md:gap-8 lg:px-8"
    >
      <div class="space-y-4">
        <Badge variant="outline" class="bg-background">
          <div class="mr-1 size-1.5 rounded-full bg-primary"></div>
          Доступны <span class="font-bold">новые</span> программы обучения
        </Badge>
        <h2 class="text-3xl font-semibold md:text-5xl lg:text-7xl">
          Научим ваших детей программировать
        </h2>
      </div>

      <p class="mx-auto max-w-xl text-muted-foreground md:text-xl">
        Мы не просто учим писать код — мы формируем цифровое мышление, которое
        поможет вашему ребёнку уверенно чувствовать себя в мире технологий.
      </p>

      <DialogTrigger
        for="callback-dialog"
        data-metric="landing-callback"
        asChild
      >
        <Button class="font-semibold">
          Узнать больше
          <PixelChevronIcon />
        </Button>
      </DialogTrigger>

      <Image
        src={Mario}
        alt=""
        class="absolute -bottom-24 left-8 hidden h-64 w-32 -rotate-10 object-contain lg:block"
      />

      <Image
        src={Ghost}
        alt=""
        class="absolute -top-24 right-4 hidden h-56 w-28 -scale-x-100 -rotate-10 object-contain lg:block"
      />
    </div>
  </section>

  <Reviews />

  <Section>
    <div class="w-full">
      <SectionHeader>
        <div class="space-y-2">
          <Badge variant="outline">
            <div class="mr-1 size-1.5 rounded-full bg-primary"></div>
            Курсы
          </Badge>
          <SectionTitle>Программы обучения</SectionTitle>
        </div>

        <SectionDescription>
          Каждая программа разработана опытными преподавателями с практическим
          опытом в IT. Мы учим детей программировать, мыслить системно и
          работать над реальными проектами.
        </SectionDescription>
      </SectionHeader>

      <SectionContent class="px-0 sm:-mb-4 lg:-mb-8">
        <Courses />
      </SectionContent>
    </div>
  </Section>

  <Section>
    <SectionContent>
      <div class="relative w-full rounded-xl p-8 md:p-16">
        <div
          class="pointer-events-none absolute inset-0 z-0 rounded-xl bg-black/70 from-black/80 via-black/50 to-transparent md:bg-transparent md:bg-linear-to-r"
        >
        </div>

        <div class="relative z-20 w-full max-w-xl space-y-4">
          <h3 class="text-2xl font-semibold text-white md:text-4xl">
            Хотите узнать, как проходят наши занятия?
          </h3>

          <p class="text-white md:text-xl">
            Приглашаем на бесплатный пробный урок — познакомимся, проведём
            практическое занятие и ответим на все ваши вопросы.
          </p>

          <DialogTrigger
            for="callback-dialog"
            data-metric="cta-callback"
            asChild
          >
            <Button class="mt-4 font-semibold">
              Записаться
              <PixelChevronIcon />
            </Button>
          </DialogTrigger>
        </div>

        <div class="absolute inset-0 -z-10">
          <Image
            src={CtaBG}
            alt=""
            class="h-full w-full rounded-xl object-cover"
          />
        </div>
      </div>
    </SectionContent>
  </Section>

  <Section>
    <SectionHeader variant="center">
      <div class="space-y-2">
        <Badge variant="outline">Галлерея</Badge>
        <SectionTitle>Моменты занятий</SectionTitle>
      </div>

      <SectionDescription>
        Живые кадры с наших занятий: дети учатся программировать, работают над
        проектами и открывают для себя мир технологий.
      </SectionDescription>
    </SectionHeader>

    <SectionContent>
      <Gallery />
    </SectionContent>
  </Section>

  <Section>
    <SectionHeader>
      <div class="space-y-2">
        <Badge variant="outline">Команда</Badge>
        <SectionTitle>Наши преподаватели</SectionTitle>
      </div>

      <SectionDescription>
        Наставники, которые не просто знают программирование, а умеют объяснять
        его детям понятно, интересно и с поддержкой.
      </SectionDescription>
    </SectionHeader>

    <SectionContent class="px-0 sm:-mb-12 lg:-mb-16">
      <Teachers />
    </SectionContent>
  </Section>

  <Section>
    <SectionHeader variant="center">
      <div class="space-y-2">
        <Badge variant="outline">Контакты</Badge>
        <SectionTitle>Связаться с нами</SectionTitle>
      </div>
    </SectionHeader>

    <SectionContent>
      <ContactUs />
    </SectionContent>
  </Section>

  <Footer />
</main>
