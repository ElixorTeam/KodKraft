---
import { Button } from "@/shared/ui/button";
import SocialTelegramIcon from "@/shared/assets/socials/telegram.svg";
import SocialVKIcon from "@/shared/assets/socials/vk.svg";
import SocialWhatsAppIcon from "@/shared/assets/socials/whatsapp.svg";
import { contacts } from "../config/contacts";
---

<footer
  class="flex h-12 w-full items-center justify-between px-4 sm:px-6 lg:px-8"
>
  <span class="text-sm">© 2018-2026 КодКрафт. Все права защищены</span>

  <div class="flex items-center gap-1">
    {
      contacts["telegram"] && (
        <Button
          href={contacts["telegram"]}
          size="icon"
          variant="ghost"
          target="_blank"
        >
          <SocialTelegramIcon class="size-6" />
          <span class="sr-only">Телеграм канал</span>
        </Button>
      )
    }

    {
      contacts["vk"] && (
        <Button
          href={contacts["vk"]}
          size="icon"
          variant="ghost"
          target="_blank"
        >
          <SocialVKIcon class="size-6" />
          <span class="sr-only">Сообщество Вконтакте</span>
        </Button>
      )
    }

    {
      contacts["whatsapp"] && (
        <Button
          href={contacts["whatsapp"]}
          size="icon"
          variant="ghost"
          target="_blank"
        >
          <SocialWhatsAppIcon class="size-6" />
          <span class="sr-only">WhatsApp</span>
        </Button>
      )
    }
  </div>
</footer>
