---
import type { HTMLAttributes } from "astro/types";
import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "@/shared/utils/cn";

type Props = HTMLAttributes<"header"> &
  VariantProps<typeof sectionHeaderVariants>;

export const sectionHeaderVariants = cva(
  "mb-8 flex flex-col space-y-2 px-4 sm:mb-12 sm:space-y-4 sm:px-6 lg:px-8",
  {
    variants: {
      variant: {
        default: "text-left",
        center: "items-center justify-center text-center"
      }
    },
    defaultVariants: {
      variant: "default"
    }
  }
);

const { class: className, variant, ...rest } = Astro.props;
---

<header
  data-slot="section-header"
  class={cn(sectionHeaderVariants({ variant }), className)}
  {...rest}
>
  <slot />
</header>
