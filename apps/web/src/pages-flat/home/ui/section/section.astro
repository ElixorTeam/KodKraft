---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@/shared/utils/cn";

type Props = HTMLAttributes<"section">;

const { class: className, ...rest } = Astro.props;
---

<section
  data-slot="section"
  class={cn(
    "relative animate-in timeline-view duration-1000 blur-in-sm md:slide-in-from-bottom-15 w-full my-12 sm:my-16 lg:my-24",
    className
  )}
  {...rest}
>
  <slot />
</section>
